# InfoPulse backend environment variables

# Node environment: development | production
NODE_ENV=development

# Server port
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/infopulse

# News API configuration
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_API_KEY=5513ccecdd894f05a19e5d32519d4d61
# Optional: default country for top-headlines endpoints (leave blank for global)
NEWS_API_DEFAULT_COUNTRY=in
# Optional: refresh interval (minutes) for scraped full article content
FULL_CONTENT_TTL_MINUTES=720

# Cache TTL in minutes for news articles
CACHE_TTL_MINUTES=10
